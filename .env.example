# ==============================================================================
# CONFIGURAÇÕES DO LLM (INTELIGÊNCIA ARTIFICIAL)
# ==============================================================================

# Defina qual provedor o projeto deverá adotar. Se for usar OpenAI, deixe como abaixo.
# Opções suportadas: openai | gemini | claude | groq
LLM_PROVIDER=openai

# Define qual modelo exato usar para o provedor selecionado.
# Padrões recomendados:
# - openai: gpt-4o
# - gemini: gemini-2.0-flash
# - claude: claude-3-5-sonnet-latest
# - groq:   llama-3.3-70b-versatile
LLM_MODEL=gpt-4o

# Informe as chaves (preencha a do seu provedor selecionado)
OPENAI_API_KEY=sk-proj-SuaChaveOpenAIAqui
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
ALPHAVANTAGE_API_KEY=

# ==============================================================================
# INTEGRAÇÕES FINANCEIRAS & MACROECONÔMICAS
# ==============================================================================

# Chave de API do FRED (Federal Reserve Economic Data).
# Como mencionado, é 100% gratuita no banco central americano para extração do histórico 
# das taxas inflacionárias e taxa de juros americana nas análises macro gringas.
# Obtenha em: https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=SuaChaveDeAtivacaoDoFredAqui

# Moeda de referência para análise de portfólio (BRL ou USD)
PORTFOLIO_REFERENCE_CURRENCY=BRL

# TTL (em segundos) para reuso de análises por ativo no modo portfólio (padrão: 24h)
PORTFOLIO_ANALYSIS_TTL=86400

# Ativa pipeline completo (6 analistas) no modo portfólio
PORTFOLIO_FULL_ANALYSIS=False
